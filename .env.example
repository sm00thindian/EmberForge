# Copy to .env and fill in your key:
#   cp .env.example .env
XAI_API_KEY=your_xai_api_key_here

# LLM (OpenAI-compatible chat completions — defaults to xAI / Grok)
EMBER_LLM_PROVIDER=grok
# EMBER_LLM_PROVIDER=claude       # uses Anthropic OpenAI-compatible API
EMBER_LLM_MODEL=grok-3-latest
# EMBER_LLM_API_URL=https://api.x.ai/v1/chat/completions
# EMBER_LLM_API_KEY=              # optional; falls back to XAI_API_KEY or ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=              # required when EMBER_LLM_PROVIDER=claude

ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_SPEED=0.9
ELEVENLABS_SENTENCE_PAUSE_SECONDS=0.4
# EMBER_TTS_PRONUNCIATIONS_FILE=prompts/tts_pronunciations.json

# Mac TTS (macos_say | elevenlabs | auto) is chosen per run via ./start_ember.sh

# Hub deployment: local (default) | docker | cloud (future hosted)
# EMBER_DEPLOYMENT=local

# Security (M7) — see docs/M7_SECURITY.md
# EMBER_ENV=development
# EMBER_ADMIN_TOKEN=
# EMBER_ADMIN_TOTP_SECRET=
# EMBER_RATE_LIMIT_ENABLED=false
# EMBER_ADMIN_SESSION_TTL_SECONDS=28800
# EMBER_PAIRING_CODE_TTL_SECONDS=300

# Conversation memory (last N turns per session_id / device_id)
# EMBER_CONVERSATION_MAX_TURNS=20
# EMBER_CONVERSATION_SESSION_TTL_SECONDS=86400

# Device wake phrase (hands-free: require "Hey Ember" before responding)
# EMBER_DEVICE_WAKE_PHRASE_ENABLED=true
# EMBER_DEVICE_WAKE_PHRASE_TIMEOUT_SECONDS=90

# Device latency (skip on-demand tool round-trips; weather still in session context)
# EMBER_DEVICE_TOOLS_ENABLED=false
# EMBER_DEVICE_MAX_TOKENS=280
# EMBER_WHISPER_MODEL=tiny

# Live context (weather, RSS, user profile) — fetched once per voice session
# EMBER_CONTEXT_ENABLED=false
# EMBER_LAT=
# EMBER_LON=
# EMBER_LOCATION_NAME=
# EMBER_TIMEZONE=America/Chicago
# EMBER_CONTEXT_PROFILE_FILE=prompts/user_context.md
# Comma-separated RSS URLs (no spaces). Starter set: US + world + conservative sources.
EMBER_RSS_FEEDS=https://feeds.npr.org/1001/rss.xml,https://feeds.bbci.co.uk/news/rss.xml,https://feeds.bbci.co.uk/news/world/rss.xml,https://moxie.foxnews.com/google-publisher/latest.xml,https://www.washingtonexaminer.com/section/news/feed,https://www.nationalreview.com/feed/
# EMBER_CONTEXT_MAX_HEADLINES=5

# On-demand tools (LLM calls weather/news APIs when asked)
# EMBER_TOOLS_ENABLED=true
# EMBER_TOOLS_MAX_ROUNDS=3

# Observability (M8)
# EMBER_LOG_JSON=false

# Optional settings
# Bind all interfaces for LAN setup/devices (use 127.0.0.1 for localhost-only)
EMBER_HOST=0.0.0.0
EMBER_DEVICE_TOKEN=
EMBER_PERSONA=ember
EMBER_WHISPER_MODEL=base
EMBER_BACKEND_URL=http://localhost:8000
EMBER_BACKEND_PORT=8000
# EMBER_INPUT_DEVICE=1