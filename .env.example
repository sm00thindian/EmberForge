# Copy to .env and fill in your key:
#   cp .env.example .env
XAI_API_KEY=your_xai_api_key_here
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Mac voice client TTS: macos_say | elevenlabs | auto
EMBER_MAC_TTS=macos_say

# Optional settings
EMBER_DEVICE_TOKEN=
EMBER_PERSONA=ember
EMBER_WHISPER_MODEL=base
EMBER_BACKEND_URL=http://localhost:8000
EMBER_BACKEND_PORT=8000
# EMBER_INPUT_DEVICE=1