{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emberforge.local/device/v1/personas.response.json",
  "title": "DevicePersonasResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["default", "personas"],
  "properties": {
    "default": { "type": "string", "minLength": 1 },
    "personas": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/personaSummary" }
    }
  },
  "$defs": {
    "personaSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "tagline", "type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "tagline": { "type": "string" },
        "type": { "type": "string", "minLength": 1 },
        "inspired_by": { "type": "string" }
      }
    }
  }
}